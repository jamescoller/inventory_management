# Copy this file to .env and fill in real values.
# .env is gitignored and lives in the repo root on the deployment machine.

# Django secret key — generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=

# Set to 0 in production, 1 for local development
DEBUG=0

# Brother QL label printer IP address on the local network
PRINTER_IP=

# Set to False to disable actual label printing (useful for testing)
ENABLE_BARCODE_PRINTING=True
